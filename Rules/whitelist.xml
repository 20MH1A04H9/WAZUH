<!-- ============================= -->
             <!-- Crash Erroe -->
<!-- ============================= -->

<group name="windows,">
  <!-- Ignore Windows Error Reporting application crash events -->
  <rule id="990020" level="0">
    <if_sid>60608</if_sid>
    <description>Ignore Windows Error Reporting APPCRASH events</description>
    <options>no_log</options>
  </rule>

  <!-- OR if you want to ignore only s3browser-helper.exe crashes -->
  <rule id="990021" level="0">
    <if_sid>60608</if_sid>
    <field name="win.eventdata.p1">^s3browser-helper\.exe$</field>
    <description>Ignore s3browser-helper.exe crash reports</description>
    <options>no_log</options>
  </rule>

  <!-- OR if you want to ignore all Event ID 1001 (Windows Error Reporting) -->
  <rule id="990022" level="0">
    <if_sid>60600</if_sid>
    <field name="win.system.eventID">^1001$</field>
    <description>Ignore all Windows Error Reporting events (Event ID 1001)</description>
    <options>no_log</options>
  </rule>
</group>
