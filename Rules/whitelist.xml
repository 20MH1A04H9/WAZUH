  <rule id="990025" level="0">
    <if_sid>60009</if_sid>
    <regex>C:\\Scripts\\Automation\\|C:\\IT-Automation\\|C:\\AdminScripts\\</regex>
    <description>Ignore legitimate internal automation PowerShell scripts.</description>
  </rule>
</group>
