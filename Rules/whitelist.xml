<group name="windows,firewall,custom">
 
  <!-- Alert when firewall is turned off -->
<rule id="990023" level="0">
<if_sid>67001</if_sid>
<description>CRITICAL: Windows Defender Firewall has been DISABLED!</description>
<group>windows_firewall,pci_dss_10.6.1,gdpr_IV_35.7.d</group>
</rule>
 
  <!-- Alert on firewall rule change -->
<rule id="990024" level="1">
<if_sid>67001</if_sid>
<description>Windows Firewall rule has been modified.</description>
<group>windows_firewall</group>
</rule>
 
</group>

