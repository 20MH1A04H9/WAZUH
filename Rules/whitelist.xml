<group name="windows,whitelist,update">

  <rule id="990026" level="0">
    <if_sid>60112</if_sid>
    
    <!-- Event ID 4907 -->
    <field name="win.system.eventID">4907</field>
    
    <!-- Only SYSTEM account -->
    <field name="win.eventdata.subjectUserSid">S-1-5-18</field>
    
    <!-- Windows Update process -->
    <field name="win.eventdata.processName">C:\\Windows\\UUS\\Packages\\Preview\\amd64\\wuaucltcore.exe</field>
    
    <!-- Only WinREAgent / WinSxS path -->
    <field name="win.eventdata.objectName">C:\\\$WinREAgent\\Scratch\\Mount\\Windows\\WinSxS\\.*</field>

    <description>Whitelisted: Windows Update audit change (Event 4907)</description>
  </rule>

<rule id="990043" level="5">
  <if_sid>60154</if_sid>
  <field name="win.eventdata.SubjectUserSid">^S-1-5-18$</field>
  <description>Admin group change by SYSTEM (possible automation)</description>
</rule>


</group>

<group name="custom_rules">

  <rule id="990044" level="8">
    <if_sid>204</if_sid>
    <description>Agent event queue flooded</description>
  </rule>



<rule id="990045" level="0">
  <if_sid>92151</if_sid>

  <field name="win.eventdata.image">C:\\Windows\\System32\\ServerManager.exe</field>
  <field name="win.eventdata.originalFileName">System\.Management\.Automation\.dll</field>

  <description>Whitelist: ServerManager loading PowerShell library</description>
</rule>
</group>


<group name="sysmon,winrm,">

  <rule id="990046" level="0">
    <if_sid>92110</if_sid>

    <!-- Ignore IPv6 loopback -->
    <field name="win.eventdata.sourceIp">^0:0:0:0:0:0:0:1$</field>
    <field name="win.eventdata.destinationIp">^0:0:0:0:0:0:0:1$</field>

    <description>Ignore WinRM loopback (::1 to ::1)</description>
  </rule>

</group>

<group name="sysmon,sysmon_eid10_detections,windows,">

  <rule id="990047" level="0">
    <if_sid>92910</if_sid>
    <field name="win.eventdata.sourceImage">ServiceShell\.exe$</field>
    <field name="win.eventdata.targetImage">Explorer\.EXE$</field>
    <description>Whitelist: Dell ServiceShell accessing Explorer (backup-related)</description>
  </rule>

</group>

<group name="windows,windows_security,policy_changed,">

  <rule id="990048" level="0">
    <if_sid>60112</if_sid>

    <!-- Dell SupportAssist process -->
    <field name="win.eventdata.processName">.*DellSupportAssistRemedationService\.exe</field>

    <!-- Only Dell remediation path -->
    <field name="win.eventdata.objectName">.*\\Dell\\SARemediation\\SystemRepair\\Snapshots\\Backup\\.*\.dll</field>

    <description>Whitelist: Dell SARemediation modifying backup DLL audit settings</description>
  </rule>

</group>


<group name="local,sysmon,windows,">

  <rule id="990049" level="0">
    <if_sid>92151</if_sid>

    <field name="win.eventdata.image">ServerManager\.exe$</field>

    <field name="win.eventdata.imageLoaded">
      System\.Management\.Automation(\.ni)?\.dll$
    </field>

    <description>
      Ignore legitimate ServerManager PowerShell automation DLL loads
    </description>
  </rule>

</group>



<group name="sonicwall,syslog">


<rule id="990050" level="0">
  <if_sid>100011</if_sid>
  <match>Google Mail|VoIP-APPS|WhatsApp|Skype|GitHub|Microsoft|AI-APPS|DNS Query|DNS Protocol|HTTP User-Agent|HTTPS Activity|HTTP Proxy|GET Method|POST Method|HEAD Method|BUSINESS-APPS|SOCIAL-NETWORKING|APP-UPDATE|ICMPv4 -- Echo Message|ICMPv4 -- Echo Reply Message|Range Header|Content-Range Header</match>
  <description>Ignore common HTTP HTTPS application control noise</description>
</rule>

<rule id="990051" level="0">
  <if_sid>100011</if_sid>
  <match>SSL/TLS|TLSv1.0|TLSv1.1|TLSv1.2|TLSv1.3</match>
  <description>Ignore SSL TLS protocol activity alerts</description>
</rule>

</group>
