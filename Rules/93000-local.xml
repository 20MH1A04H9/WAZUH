<!-- ============================= -->
 <!-- Privilege Escalation Attempt -->
<!-- ============================= -->
<group name="windows,powershell,">

  <!-- Rule to detect PowerShell launched with elevated token -->
  <rule id="111012" level="7">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.newProcessName" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.tokenElevationType">%%1937</field>
    <description>PowerShell executed with administrative privileges (Elevated Token)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>powershell_admin,windows_security,</group>
  </rule>

  <!-- Alternative rule checking for high integrity level (admin) -->
  <rule id="111011" level="7">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.newProcessName" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.mandatoryLabel">S-1-16-12288</field>
    <description>PowerShell executed with high integrity level (Administrator)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>powershell_admin,windows_security,</group>
  </rule>

  <!-- Comprehensive rule combining both conditions -->
  <rule id="111010" level="8">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.newProcessName" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.tokenElevationType">%%1937</field>
    <field name="win.eventdata.mandatoryLabel">S-1-16-12288</field>
    <description>PowerShell launched as Administrator (Full elevated privileges detected)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>powershell_admin,privilege_escalation,windows_security,</group>
  </rule>
</group>
<!-- ============================= -->
             <!-- END -->
