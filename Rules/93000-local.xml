<!-- Credential Dumping Detection -->
<!-- ============================= -->
<group name="windows,mimikatz,">
  <!-- Rule for suspicious process creation (Event ID 4688) -->
  <rule id="110601" level="12">
    <if_sid>67027</if_sid> <!-- Wazuh rule for Event ID 4688 -->
    <field name="win.eventdata.newProcessName">mimikatz.exe</field>
    <description>Mimikatz process creation detected</description>
    <mitre>
      <id>T1003</id> <!-- MITRE ATT&CK: OS Credential Dumping -->
    </mitre>
  </rule>

  <rule id="110602" level="12">
  <if_sid>60107</if_sid>
  <field name="win.eventdata.processName" type="pcre2">\\\\mimikatz.exe</field>
  <description>Possible memory dump detected</description>
  </rule>
</group>
