<group name="syscheck,malware_detection,">
  <!-- Rule for file added to monitored directories -->
  <rule id="130200" level="7">
    <if_sid>554</if_sid>
    <field name="file">\.exe$|\.dll$|\.bat$|\.ps1$|\.vbs$</field>
    <description>File added to monitored directory with suspicious extension.</description>
    <group>pci_dss_11.5,nist_800_53_SI.7,</group>
  </rule>
  <!-- Rule for VirusTotal detecting malicious file -->
  <rule id="130201" level="12">
    <if_sid>87105</if_sid>
    <field name="virustotal.malicious">1</field>
    <description>VirusTotal: Malicious file detected in monitored directory.</description>
    <group>pci_dss_11.4,nist_800_53_SI.3,</group>
  </rule>
</group>

<!-- ============================= -->
             <!-- END -->
