<!--
=============================================================================
  agent.conf — DC group — Advanced SOC + EDR
  Wazuh Manager : aiwazuh.socexperts.space
  Group         : DC (rename to your actual group, e.g. VISWA-DC)
  Target OS     : Windows Server 2022 — Domain Controller

  BASE: Same Security/System/Application/Sysmon/PowerShell/Defender/
  Firewall/TaskScheduler/WMI/WinRM/RDP/BITS/CodeIntegrity/GroupPolicy/
  DNS-Client/DriverFrameworks blocks as your Windows 11 EDR config —
  copied unchanged below.

  REMOVED vs Windows 11 baseline:
    - Microsoft-Windows-SmartScreen/Debug
      (not meaningful on a server — no interactive user browsing/downloads)
    - Microsoft-Windows-AppLocker/Packaged app-Deployment
      (Store-app AppLocker rules don't apply to Server SKUs; keeping the
      EXE/DLL and MSI/Script AppLocker channels since those still fire on
      servers if you have AppLocker policies applied)

  ADDED for Domain Controller role:
    - Directory Service (AD replication health / lingering objects / KCC)
    - DFS Replication (SYSVOL replication health)
    - DNS Server (zone transfer / dynamic update anomalies) — only add this
      block if this DC also runs the DNS Server role
    - Microsoft-Windows-NTLM/Operational (NTLM auth auditing — requires
      "Network security: Restrict NTLM" audit GPOs enabled to populate)
    - Security log query extended with AD CS certificate-issuance EventIDs
      (4870, 4882, 4885–4899) — only useful if this DC also hosts AD CS.
      If this DC is NOT a CA, you can strip those IDs back out; they'll
      just never fire.

  CAVEAT (read before deploying):
    The Directory Service, DFS Replication, and DNS Server EventID lists
    below are curated from common DC-monitoring references, not pulled
    from a live event log on your AIWAZUH manager. Validate against
    actual `Get-WinEvent` output on one DC before trusting them in
    production — event log EventIDs shift slightly across log providers
    and DC functional levels, and I'd rather you catch a wrong ID than
    silently miss detections. Security/System/Application/Sysmon/
    PowerShell blocks are the well-documented, high-confidence ones.
=============================================================================
-->
<agent_config>

  <!-- ================================================================
     ANTI-FLOOD BUFFER — DCs generate more Security log volume than
     workstations (auth + replication traffic). Bump events_per_second.
     ================================================================ -->
  <client_buffer>
    <disabled>no</disabled>
    <queue_size>15000</queue_size>
    <events_per_second>1000</events_per_second>
  </client_buffer>

  <!-- ================================================================
     SECURITY EVENT LOG — Advanced SOC Whitelist + AD CS cert events
     Same base list as Windows 11 config, EXTENDED with:
       4870  Certificate Services revoked a certificate
       4882  Security permissions changed for CS
       4885  Audit filter for CS changed
       4886  CS received a certificate request
       4887  CS approved a request / issued a cert
       4888  CS denied a request
       4889  CS set a request into pending state
       4890  Certificate Manager settings changed
       4891  Config entry changed
       4892  CA certificate changed
       4893  CS archived a key
       4894  CS imported/published a certificate
       4895  Certificate Services archived a key
       4896  One or more rows deleted from cert DB
       4897  Role separation enabled
       4898  CS loaded a template
       4899  CS template updated
     ================================================================ -->
  <localfile>
    <location>Security</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <reconnect_time>5s</reconnect_time>
    <query>Event/System[EventID!=4634 and EventID!=4658 and EventID!=4703 and EventID!=4985 and EventID!=4799 and EventID!=5145 and EventID!=5152 and EventID!=5153 and EventID!=5156 and EventID!=5157 and EventID!=5158 and EventID!=5447] and (Event/System[EventID!=4624] or Event/EventData[Data[@Name='AuthenticationPackageName']='NTLM'])</query>
  </localfile>

  <!-- ================================================================
     SYSTEM EVENT LOG — unchanged from Windows 11 baseline
     ================================================================ -->
  <localfile>
    <location>System</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[(EventID=104 or EventID=1001 or EventID=1014 or EventID=1074 or EventID=1076 or EventID=6005 or EventID=6006 or EventID=6008 or EventID=6009 or EventID=6013 or EventID=7000 or EventID=7001 or EventID=7009 or EventID=7011 or EventID=7023 or EventID=7024 or EventID=7026 or EventID=7031 or EventID=7034 or EventID=7035 or EventID=7040 or EventID=7045) and EventID!=7036]</query>
  </localfile>

  <!-- ================================================================
     APPLICATION EVENT LOG — unchanged from Windows 11 baseline
     ================================================================ -->
  <localfile>
    <location>Application</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[(EventID=1000 or EventID=1001 or EventID=1002 or EventID=1026 or EventID=1034) and (Level=1 or Level=2)]</query>
  </localfile>

  <!-- ================================================================
     SYSMON — unchanged from Windows 11 baseline. Full EID 1-29 coverage.
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-Sysmon/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=1 or EventID=2 or EventID=3 or EventID=5 or EventID=6 or EventID=7 or EventID=8 or EventID=9 or EventID=10 or EventID=11 or EventID=12 or EventID=13 or EventID=14 or EventID=15 or EventID=16 or EventID=17 or EventID=18 or EventID=19 or EventID=20 or EventID=21 or EventID=22 or EventID=23 or EventID=24 or EventID=25 or EventID=26 or EventID=27 or EventID=28 or EventID=29]</query>
  </localfile>

  <!-- ================================================================
     POWERSHELL SCRIPT BLOCK LOGGING — unchanged
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-PowerShell/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=4103 or EventID=4104 or EventID=4105 or EventID=4106 or EventID=40961 or EventID=40962]</query>
  </localfile>
  <localfile>
    <location>Windows PowerShell</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=400 or EventID=403 or EventID=500 or EventID=600 or EventID=800]</query>
  </localfile>

  <!-- ================================================================
     MICROSOFT DEFENDER — keep only if RTP is actually running on this
     DC. Some environments exclude AV agents from DCs; if so, delete
     this block, it'll just sit idle otherwise.
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-Windows Defender/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=1006 or EventID=1007 or EventID=1008 or EventID=1009 or EventID=1010 or EventID=1013 or EventID=1014 or EventID=1015 or EventID=1116 or EventID=1117 or EventID=1118 or EventID=1119 or EventID=2001 or EventID=2002 or EventID=2003 or EventID=2004 or EventID=2005 or EventID=2006 or EventID=2007 or EventID=2010 or EventID=2011 or EventID=3002 or EventID=3007 or EventID=5001 or EventID=5004 or EventID=5007 or EventID=5008 or EventID=5009 or EventID=5010 or EventID=5012]</query>
  </localfile>

  <!-- ================================================================
     WINDOWS FIREWALL — unchanged
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-Windows Firewall With Advanced Security/Firewall</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=2003 or EventID=2004 or EventID=2005 or EventID=2006 or EventID=2009 or EventID=2033 or EventID=2052]</query>
  </localfile>

  <!-- ================================================================
     TASK SCHEDULER — unchanged
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-TaskScheduler/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=106 or EventID=140 or EventID=141 or EventID=200 or EventID=201]</query>
  </localfile>

  <!-- ================================================================
     WMI ACTIVITY — unchanged
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-WMI-Activity/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=5857 or EventID=5858 or EventID=5859 or EventID=5860 or EventID=5861]</query>
  </localfile>

  <!-- ================================================================
     WINRM — unchanged (this is the primary lateral-movement path
     between a compromised workstation and a DC — do not drop it)
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-WinRM/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=6 or EventID=8 or EventID=15 or EventID=16 or EventID=33 or EventID=91 or EventID=168]</query>
  </localfile>

  <!-- ================================================================
     RDP / TERMINAL SERVICES — unchanged
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-TerminalServices-LocalSessionManager/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=21 or EventID=22 or EventID=23 or EventID=24 or EventID=25 or EventID=39 or EventID=40]</query>
  </localfile>
  <localfile>
    <location>Microsoft-Windows-TerminalServices-RemoteConnectionManager/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=261 or EventID=1149 or EventID=1158]</query>
  </localfile>

  <!-- ================================================================
     BITS CLIENT — unchanged
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-Bits-Client/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=3 or EventID=59 or EventID=60 or EventID=61]</query>
  </localfile>

  <!-- ================================================================
     APPLOCKER — EXE/DLL and MSI/Script only (Packaged-app block
     dropped, not meaningful on Server SKUs)
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-AppLocker/EXE and DLL</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
  </localfile>
  <localfile>
    <location>Microsoft-Windows-AppLocker/MSI and Script</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
  </localfile>

  <!-- ================================================================
     CODE INTEGRITY / WDAC — unchanged
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-CodeIntegrity/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=3001 or EventID=3002 or EventID=3003 or EventID=3004 or EventID=3010 or EventID=3023 or EventID=3033 or EventID=3034 or EventID=3076 or EventID=3077 or EventID=3089 or EventID=3099]</query>
  </localfile>

  <!-- ================================================================
     GROUP POLICY — unchanged. Extra important on a DC: this is where
     GPO tampering shows up first.
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-GroupPolicy/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=1085 or EventID=1125 or EventID=1127 or EventID=1129]</query>
  </localfile>

  <!-- ================================================================
     DNS CLIENT — unchanged (this DC's own outbound resolutions)
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-DNS-Client/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=3006 or EventID=3008 or EventID=3020]</query>
  </localfile>

  <!-- ================================================================
     DRIVER FRAMEWORK — unchanged
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-DriverFrameworks-UserMode/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=2003 or EventID=2004 or EventID=2100 or EventID=2101]</query>
  </localfile>

  <!-- ================================================================
     DIRECTORY SERVICE — AD replication health, KCC failures, USN
     rollback, lingering objects. NEW for DC role.
     EID 1084/1311  KCC / topology generation failed
     EID 1388/1988  Lingering object detected
     EID 1655       Attribute failed to update
     EID 1925/1926  Replication link add/verify failed
     EID 2042       Has not replicated in tombstone-lifetime window
     ================================================================ -->
  <localfile>
    <location>Directory Service</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=1084 or EventID=1311 or EventID=1388 or EventID=1655 or EventID=1925 or EventID=1926 or EventID=1988 or EventID=2042]</query>
  </localfile>

  <!-- ================================================================
     DFS REPLICATION — SYSVOL health. A broken/attacker-tampered
     SYSVOL is a common GPO-based persistence indicator. NEW for DC.
     EID 4614  Vol not initialized
     EID 5002  Attempted to communicate w/ down partner
     EID 5004  Staging area quota exceeded
     EID 5014  Deleted a member of a replicated folder
     EID 6404  SYSVOL couldn't complete initial replication
     EID 8004  Initial sync completed for SYSVOL
     EID 8014  Journal wrap detected (deletes replication state — rare
                but a big deal if it happens unexpectedly)
     ================================================================ -->
  <localfile>
    <location>DFS Replication</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=4614 or EventID=5002 or EventID=5004 or EventID=5014 or EventID=6404 or EventID=8004 or EventID=8014]</query>
  </localfile>

  <!-- ================================================================
     NTLM OPERATIONAL — NTLM downgrade / relay-adjacent auth auditing.
     Requires "Network security: Restrict NTLM: Audit..." GPOs enabled
     to actually populate — otherwise this channel stays empty.
     ================================================================ -->
  <localfile>
    <location>Microsoft-Windows-NTLM/Operational</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
  </localfile>

  <!-- ================================================================
     DNS SERVER — only include this block if this DC also holds the
     DNS Server role. Watches for zone transfer abuse and dynamic
     update anomalies (DNS spoofing / AD-integrated zone poisoning).
     UNVERIFIED against a live log — confirm EventIDs on your box
     before relying on this for detection.
     ================================================================ -->
  <localfile>
    <location>DNS Server</location>
    <log_format>eventchannel</log_format>
    <only-future-events>yes</only-future-events>
    <query>Event/System[EventID=2 or EventID=3 or EventID=6 or EventID=150 or EventID=411 or EventID=412 or EventID=413 or EventID=414 or EventID=415 or EventID=770 or EventID=3150 or EventID=3151 or EventID=6527]</query>
  </localfile>

</agent_config>
