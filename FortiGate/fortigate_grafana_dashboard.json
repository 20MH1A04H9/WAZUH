    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" },
    { "type": "panel", "id": "logs", "name": "Logs", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "geomap", "name": "Geomap", "version": "" }
  ],
  "annotations": {
    "list": [{ "builtIn": 1, "datasource": "-- Grafana --", "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }]
  },
  "description": "FortiGate Firewall Log Analysis Dashboard - Traffic, Threats, Geo Intelligence",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔥 FortiGate Overview",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "mappings": [],
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Events",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "sum(count_over_time({job=\"fortigate\"}[$__range]))",
        "legendFormat": "Total",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Denied Traffic",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "sum(count_over_time({job=\"fortigate\", action=\"deny\"}[$__range]))",
        "legendFormat": "Denied",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "SSL Alerts",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "sum(count_over_time({job=\"fortigate\"} |= \"SSL alerts\" [$__range]))",
        "legendFormat": "SSL",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Allowed Traffic",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "sum(count_over_time({job=\"fortigate\", action=\"accept\"}[$__range]))",
        "legendFormat": "Allowed",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Unique Source Countries",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "count(count by (srccountry) (count_over_time({job=\"fortigate\"}[$__range])))",
        "legendFormat": "Countries",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Server RST Events",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "sum(count_over_time({job=\"fortigate\", action=\"server-rst\"}[$__range]))",
        "legendFormat": "RST",
        "refId": "A"
      }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📈 Traffic Timeline",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Traffic Events Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({job=\"fortigate\", action=\"deny\"}[$__interval]))",
          "legendFormat": "Denied",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({job=\"fortigate\", action=\"accept\"}[$__interval]))",
          "legendFormat": "Allowed",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({job=\"fortigate\", action=\"server-rst\"}[$__interval]))",
          "legendFormat": "Server-RST",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(rate({job=\"fortigate\"}[$__interval]))",
          "legendFormat": "All Events",
          "refId": "D"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "🌍 Geo Intelligence",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
