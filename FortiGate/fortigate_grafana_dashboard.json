        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "expr": "sum by (action) (count_over_time({job=\"fortigate\"}[$__range]))",
        "legendFormat": "{{action}}",
        "refId": "A"
      }]
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
