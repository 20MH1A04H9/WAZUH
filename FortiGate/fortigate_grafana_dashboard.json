    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 104,
      "title": "🔍 Top Talkers & Services",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 50 }] },
          "custom": { "align": "auto", "displayMode": "color-background" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "srccountry" }, "properties": [{ "id": "displayName", "value": "Source Country" }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Event Count" }, { "id": "custom.width", "value": 120 }] }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 34 },
      "id": 30,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Event Count" }] },
